# Porta em que a API irá escutar
PORT=3001

# MongoDB
MONGO_URI=mongodb://user:password@localhost:27017/dbname?authSource=dbname

# Chaves JWT em Base64 (RSA 2048-bit)
# Gere com:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 -w 0
#   cat public.pem  | base64 -w 0
JWT_PRIVATE_KEY=<base64 da chave privada RSA>
JWT_PUBLIC_KEY=<base64 da chave pública RSA>

# Usuário de teste (usado em testes E2E)
TEST_USER=usuario@exemplo.com
TEST_USER_PASSWORD_HASH=<hash bcrypt da senha>
