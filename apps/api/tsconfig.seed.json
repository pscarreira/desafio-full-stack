  "compilerOptions": {
    "outDir": "./dist-seed",
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/**/*.ts"
  ],
  "exclude": [
