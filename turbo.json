{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"test:watch": {
			"cache": false,
			"persistent": true
		},
		"test:cov": {
			"dependsOn": ["^build"],
			"outputs": ["coverage/**"]
		},
		"test:e2e:api": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"test:e2e:web": {
			"dependsOn": ["^build"],
			"cache": false
		},
		"test:e2e:web:ui": {
			"cache": false,
			"persistent": true
		},
		"seed": {
			"cache": false
		}
	}
}
